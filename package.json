{
  "name": "zipmover",
  "version": "1.0.0",
  "description": "Automated zip file deployment tool for development projects",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder"
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "chokidar": "^3.5.3",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.zipmover.app",
    "productName": "ZipMover",
    "directories": {
      "output": "dist"
    },
    "win": { "target": "nsis" },
    "mac": { "target": "dmg" },
    "linux": { "target": "AppImage" }
  }
}
